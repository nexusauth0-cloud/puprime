generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Click {
  id        String   @id @default(cuid())
  source    String
  userAgent String?
  ipAddress String?
  createdAt DateTime @default(now())
  @@map("clicks")
}

model Registration {
  id              String   @id @default(cuid())
  fullName        String
  whatsappNumber  String   @unique
  email           String?
  source          String?
  createdAt       DateTime @default(now())
  @@map("registrations")
}
