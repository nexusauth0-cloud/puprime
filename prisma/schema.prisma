generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Click {
  id        String   @id @default(cuid())
  source    String
  type      String   @default("go")
  userAgent String?
  ipAddress String?
  createdAt DateTime @default(now())
  @@index([source])
  @@index([createdAt])
  @@map("clicks")
}

enum RegistrationStatus {
  registered
  attended
  cancelled
  no_show
}

model Registration {
  id              String               @id @default(cuid())
  fullName        String
  whatsappNumber  String               @unique
  email           String?
  source          String?
  referredBy      String?
  status          RegistrationStatus   @default(registered)
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt
  @@map("registrations")
}

model Referral {
  id         String   @id @default(cuid())
  referrerId String
  referredId String
  source     String?
  createdAt  DateTime @default(now())
  @@map("referrals")
}

model LiveUser {
  id        String   @id @default(cuid())
  sessionId String   @unique
  source    String?
  lastSeen  DateTime @updatedAt
  @@map("live_users")
}
